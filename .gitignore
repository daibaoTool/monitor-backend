# ─── 依赖 ─────────────────────────────────────────────────────────────────────
node_modules/

# ─── 编译产物 ─────────────────────────────────────────────────────────────────
dist/

# ─── 环境变量（含密钥，禁止提交） ──────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── 数据库文件 ────────────────────────────────────────────────────────────────
# /database/ 只忽略根目录下的数据目录（SQLite 持久化文件）
# 不能写 database/（无前导斜杠会匹配所有层级，会误忽略 src/database/ 源码）
/database/
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ─── 日志 ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
