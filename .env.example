# ─── 服务配置 ─────────────────────────────────────────────────────────────────
PORT=3100

# ─── 跨域白名单（多个域名用逗号分隔）────────────────────────────────────────────
# 本地开发示例：http://localhost:3000,http://localhost:5173
# 生产示例：https://your-app.com,https://another-app.com
# 留空则拒绝所有跨域请求（同域 nginx 反代场景无需配置）
CORS_ORIGIN=

# ─── Node 环境 ────────────────────────────────────────────────────────────────
NODE_ENV=development
